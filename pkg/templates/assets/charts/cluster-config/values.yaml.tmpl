#
# Fonte única de verdade para configurações dinâmicas
# Somente referências a Secrets/SealedSecrets; nunca coloque segredos aqui
# Todos os campos possuem defaults seguros para não quebrar ambientes existentes
#

global:
  clusterName: "{{ .ProjectName }}"
  environment: "{{ .Environment }}"
  domainBase: "" # vazio -> não cria Ingress; usa NodePort/port-forward

repository:
  url: "{{ .GitRepo }}"
  branch: "{{ .GitBranch }}"
  organization: "{{ .GithubOrg }}"

ingress:
  enabled: false
  tls:
    enabled: false
    certResolver: "letsencrypt"
    email: "{{ .Email }}"
  whitelist:
    enabled: false
    sourceRanges: [] # lista de CIDR/IPs permitidos. SE HABILITADO, aplica-se a TODOS os ingresses (ArgoCD, MinIO, Grafana, Traefik, etc)

hosts:
  argocd: ""
  traefik: ""
  grafana: ""
  webhook: ""
  minio: ""
  minioConsole: ""

argocd:
  enabled: false
  namespace: "argocd"
  project: "{{ .ProjectName }}"
  url: "" # default derivado de hosts.argocd
  repositories: [] # ex.: [{type: git, url: https://github.com/... , name: app}]

events:
  enabled: false
  webhook:
    port: 12000
    serviceType: NodePort
    nodePort: 30012
  sensor:
    ref: "refs/heads/{{ .GitBranch }}"
    repoName: "{{ .ProjectName }}"

applicationset:
  enabled: false
  namespace: "argocd"
  organization: "{{ .GithubOrg }}"
  branch: ""
  labelMatch: "{{ .ProjectName }}-app"
  pathsExist: ["k8s"]
  requeueAfterSeconds: 300

discovery:
  enabled: true
  organization: "{{ .GithubOrg }}"
  # Tópico GitHub usado para filtrar quais repositórios serão deployados (AppSet)
  # IMPORTANTE: Se mudar aqui, deve adicionar este tópico nos seus repositórios!
  topic: "yby-cluster"

storage:
  minio:
    enabled: false
    namespace: "storage"
    endpoints:
      api: "" # default derivado de hosts.minio
      console: "" # default derivado de hosts.minioConsole
    secretName: "minio-secret"
    autoBootstrap:
      enabled: false
      buckets: []

validation:
  enabled: true # hooks de validação de referências a Secrets

#
# Ecofuturismo & Observabilidade
#
kepler:
  enabled: false # Habilitado apenas quando selecionado via --enable-kepler; sobrescrito pelos values de ambiente
  serviceMonitor:
    enabled: false # Habilitar se usar Prometheus Operator

keda:
  enabled: false # Habilitado apenas quando selecionado via --enable-keda; sobrescrito pelos values de ambiente



observability:
  mode: "prometheus" # options: none, prometheus

# Configuração de Segurança
security:
  networkPolicy:
    enabled: true # Alinhado com cluster-values.yaml — bloqueia tráfego por padrão

# Configuração do Subchart MinIO
minio:
  mode: standalone
  replicas: 1
  existingSecret: "minio-secret" # Criado imperativamente pelo Makefile (bootstrap)
  ingress:
    enabled: false
    ingressClassName: ""
    hosts: []
  consoleIngress:
    enabled: false
    ingressClassName: ""
    hosts: []
  persistence:
    enabled: true
    size: 10Gi
  resources:
    requests:
      memory: 256Mi
      cpu: 100m
  buckets: []
