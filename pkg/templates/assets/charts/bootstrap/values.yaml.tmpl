# Valores padrão do Chart Bootstrap
# IMPORTANTE: Estes valores são OVERRIDDEN por config/cluster-values.yaml
# Apenas para referência/documentação dos campos disponíveis

# Repositório Git do Cluster
git:
  repoURL: "{{ .GitRepo }}"
  targetRevision: {{ .GitBranch }}
  branch: {{ .GitBranch }}
  repoName: "{{ .ProjectName }}"
  provider: "{{ resolveGitProvider "github" }}"

headlamp:
  enabled: false

project: {{ .ProjectName }}

# Namespaces do Sistema (parametrizáveis via enterprise overrides)
namespaces:
  argocd: "{{ resolveNS "argocd" }}"
  argoEvents: "{{ resolveNS "argo-events" }}"
  monitoring: "{{ resolveNS "monitoring" }}"
  ingressSystem: "{{ resolveNS "ingress-system" }}"
  storage: "{{ resolveNS "storage" }}"
  keda: "{{ resolveNS "keda" }}"

# Configurações do Argo CD
argocd:
  namespace: {{ resolveNS "argocd" }}
  project: {{ .ProjectName }}
  destinationServer: {{ .DestinationServer | default "https://kubernetes.default.svc" }}

# Configurações de Eventos (Argo Events)
events:
  enabled: true
  eventbus:
    replicas: 1
    storageClass: {{ resolveStorage "local-path" }}
  webhook:
    port: 12000
    serviceType: NodePort
    nodePort: 30012

# Aplicação Helm para configuração centralizada
clusterConfig:
  enabled: true
  valueFiles:
    - config/cluster-values.yaml

# Resources profiles (small/medium/large via enterprise overrides)
resources:
  profile: "{{ .Overrides.Profiles.Resources }}"
  eventbus:
    requests:
      cpu: "{{ (resourceProfile).CPURequest }}"
      memory: "{{ (resourceProfile).MemoryRequest }}"
    limits:
      cpu: "{{ (resourceProfile).CPULimit }}"
      memory: "{{ (resourceProfile).MemoryLimit }}"

# Observabilidade
observability:
  enabled: false
  mode: "{{ resolveObservability "prometheus" }}"
  grafana:
    enabled: false
    # Usar existingSecret para senha do Grafana em produção:
    # existingSecret: grafana-admin-secret
    # Para desenvolvimento local, definir adminPassword no values do ambiente
    adminPassword: ""
  prometheus:
    enabled: true
    retention: "10d"
  alertmanager:
    enabled: false


# Descoberta Automática de Aplicações (Zero-Touch)
discovery:
  enabled: {{ .GithubDiscovery }}  # Override: discovery.enabled
  scmProvider: "{{ resolveGitProvider "github" }}"
  organization: "{{ .GithubOrg }}"  # Override: discovery.organization
  topic: "yby-cluster"  # Default topic for discovery
  tokenSecretName: github-token
  tokenSecretKey: token

# Controla uso de manifests legados por Kustomize
legacy:
  enabled: false

# Armazenamento (MinIO) - Defaults
storage:
  minio:
    enabled: false

# Imagens de containers (parametrizáveis via enterprise overrides)
images:
  kubectl: "{{ resolveImage "bitnami/kubectl:1.31" }}"
  ubuntu: "{{ resolveImage "ubuntu:22.04" }}"
  alpineGit: "{{ resolveImage "alpine/git:2.43.0" }}"
  argocd: "{{ resolveImage "argoproj/argocd:v2.13.3" }}"
  curl: "{{ resolveImage "curlimages/curl:8.11.1" }}"
{{- if hasRegistryPullSecret }}
imagePullSecrets:
  - name: {{ registryPullSecret }}
{{- end }}

minio:
  mode: standalone
  replicas: 1
  existingSecret: "minio-secret"
  ingress:
    enabled: false
  persistence:
    enabled: true
    size: 10Gi
  resources:
    requests:
      memory: 256Mi
      cpu: 100m
  buckets: []

# Scaling - Defaults
keda:
  enabled: false

kepler:
  enabled: false
  serviceMonitor:
    enabled: false

# Connectivity - Defaults
ingress:
  enabled: true
  className: "{{ resolveIngress "traefik" }}"
  tls:
    enabled: true
    issuer: {{ resolveTLSIssuer "letsencrypt-staging" }}
    email: {{ .Email }}
    caSecretName: ""
    acmeSolver: "http01"

# Versões de charts (parametrizáveis via enterprise overrides)
versions:
  keda: "{{ resolveChartVersion "keda" "2.14.2" }}"
  kepler: "{{ resolveChartVersion "kepler" "0.5.11" }}"

# Labels customizadas para namespaces (enterprise overrides)
customLabels:{{ nsLabels 2 }}

# Cloud provider (preparatório para annotations condicionais)
cloud:
  provider: "{{ resolveCloudProvider }}"

# Hosts Definitions (Used by Ingresses)
hosts: {}



