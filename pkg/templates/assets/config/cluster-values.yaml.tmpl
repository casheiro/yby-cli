# ==============================================
# Yby - Configuração do Cluster
# ==============================================
# IMPORTANTE: Este arquivo reflete o ambiente INICIAL do projeto ({{ .Environment }}).
# Para ambientes superiores (staging, prod), use os values específicos em
# config/values-{env}.yaml que sobrescrevem estas configurações via Helm merge.
# ==============================================

# Configuração do Argo CD (Bootstrap)
# Estas chaves são usadas quando passamos este arquivo para o chart 'argo/argo-cd'
server:
  service:
    type: ClusterIP
  # Modo inseguro apenas para ambientes locais/dev (port-forward)
  insecure: {{ if or (eq .Environment "local") (eq .Environment "dev") }}true{{ else }}false{{ end }}
  {{- if or (eq .Environment "local") (eq .Environment "dev") }}
  extraArgs:
    - --insecure
  {{- end }}

# Configuração de Segurança (Hardening)
security:
  secrets:
    # Monta segredos em RAM (/run/secrets) em vez de EnvVars
    mountPath: "/run/secrets"
    enabled: true
  networkPolicy:
    # Bloqueia tráfego de entrada por padrão no namespace infra
    enabled: true

# Configuração do Sistema (Fase 0)
system:
  k3s:
    version: "v1.31.2+k3s1" # Versão utilizada pelo yby bootstrap vps

# Configuração Eco-Friendly (Fase 1)


# Definição de Namespaces do Sistema
namespaces:
  argocd: {{ resolveNS "argocd" }}
  ingress: {{ resolveNS "ingress-system" }}
  events: {{ resolveNS "argo-events" }}
  monitoring: {{ resolveNS "monitoring" }}
  storage: {{ resolveNS "storage" }}
  keda: {{ resolveNS "keda" }}

global:
  # Ambiente (dev, staging, prod)
  environment: {{ .Environment }}
  # Domínio base para Ingresses (ex: cluster.example.com)
  domainBase: "{{ .Domain }}"

git:
  # Repositório de origem deste template (será substituído pelo seu)
  repoURL: {{ .GitRepo }}
  branch: {{ .GitBranch }}
  repoName: {{ .ProjectName }}

# Descoberta Automática de Aplicações
discovery:
  enabled: {{ .GithubDiscovery }}
  organization: "{{ .GithubOrg }}"
  topic: {{ .ProjectName }}-app
  # Secret name para token do GitHub (não altere a menos que saiba o que está fazendo)
  tokenSecretName: github-token

ingress:
  enabled: true
  tls:
    enabled: true
    # Email para Let's Encrypt (Certificados HTTPS automáticos)
    email: {{ .Email }}
    # Nome do ClusterIssuer (letsencrypt-prod é o padrão para produção com limites reais)
    # Use 'letsencrypt-staging' para testes se estiver depurando.
    issuer: {{ if eq .Environment "prod" }}letsencrypt-prod{{ else }}letsencrypt-staging{{ end }}

# Stack de Observabilidade (Prometheus + Grafana + Kepler)
observability:
  mode: prometheus
  prometheus:
    retention: "5d" # Retenção reduzida
    resources:
      requests:
        memory: 400Mi # Otimizado para VPS pequeno

kepler:
  enabled: {{ .EnableKepler }}

# Autoscaling (KEDA)
keda:
  enabled: {{ .EnableKEDA }}

# Armazenamento de Objetos (MinIO)
storage:
  minio:
    enabled: {{ .EnableMinio }}
