#!/bin/sh
# Native Pre-commit Hook (No Husky/Node required)

# Evita warnings de locale no WSL que corrompem a saída do goenv/go env
export LC_ALL=C.UTF-8
export LANG=C.UTF-8

echo "🔍 Running Local Linting (Core)..."

# Run fast lint (excluding heavy k8s parts to match CI Core Lint)
if command -v golangci-lint >/dev/null 2>&1; then
    golangci-lint run --exclude-dirs plugins/sentinel/cli,pkg/plugin/sdk --timeout=2m ./...
else
    echo "⚠️ golangci-lint not found. Skipping linting."
    exit 0
fi

if [ $? -ne 0 ]; then
    echo "❌ Linting completed with errors. Commit aborted."
    exit 1
fi

echo "✅ Linting passed."
